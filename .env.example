# Copy this file to .env and fill in real values.
# .env is gitignored — never commit real credentials.

# AltoControl (Penicor) — Azure SQL
ALTOCONTROL_SERVER=logicoac.database.windows.net
ALTOCONTROL_DATABASE=Penicor
ALTOCONTROL_USER=
ALTOCONTROL_PASSWORD=

# Optional: pin the ODBC driver name. If unset, the script auto-detects
# (Driver 18 > 17 > older). Set this if you want to force a specific one.
# ALTOCONTROL_DRIVER=ODBC Driver 17 for SQL Server

# Local Postgres for dev (matches compose.yml). The text2sql agent reads this.
PENICOR_DB_URL=postgresql+psycopg://penicor:penicor@localhost:5433/penicor?options=-csearch_path%3Dgold

# OpenRouter (recommended) — OpenAI-API-compatible router fanning out to many providers.
# Get a key at https://openrouter.ai/keys. The demo aliases these to OPENAI_API_KEY /
# OPENAI_BASE_URL automatically.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Optional: direct Anthropic key. Only used if OPENROUTER_API_KEY is unset.
# ANTHROPIC_API_KEY=

# LangSmith (optional) — visual call-tree of agent runs at smith.langchain.com.
# When set, the LangChain stack auto-instruments and emits traces. Canonical
# hits bypass the LLM so they don't appear here — only agent-path runs do.
# LANGSMITH_TRACING=true
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com
# LANGSMITH_API_KEY=lsv2_pt_...
# LANGSMITH_PROJECT=penicor-poc
